# Optional CDN root for target bundles (no trailing slash).
# Required for guest targets on the deployed AR app (phones cannot read local booth files).
# Example (Cloudflare R2 public bucket):
# VITE_BUNDLE_CDN_URL=https://pub-xxxx.r2.dev/webar-targets

# Public web app URL used in kiosk QR codes (your Vercel deployment).
# Also set the same value as app_url in kiosk/config.json on the booth PC.
# VITE_PUBLIC_APP_URL=https://your-app.vercel.app

# Used when the URL has no ?target= param (demo / single-target deployments).
VITE_DEFAULT_TARGET=target_001

# Booth PC local API (only needed when kiosk UI is not served via Vite dev proxy).
# Leave unset for local dev — Vite proxies /api to http://127.0.0.1:8787.
# For deployed kiosk on Vercel opening from booth browser:
# VITE_KIOSK_API_URL=http://127.0.0.1:8787
