{
  "app_url": "https://your-app.vercel.app",
  "bundle_root": "../assets/targets",
  "output_root": "./output",
  "captures_root": "./captures",
  "notes": "app_url = Vercel URL for QR codes. cdn = required for guest targets on phones. Vercel env: VITE_BUNDLE_CDN_URL + VITE_PUBLIC_APP_URL.",
  "api": {
    "host": "127.0.0.1",
    "port": 8787,
    "allowed_origins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "https://your-app.vercel.app"
    ]
  },
  "cdn": {
    "endpoint_url": "https://ACCOUNT_ID.r2.cloudflarestorage.com",
    "bucket": "webar-targets",
    "access_key_id": "YOUR_R2_ACCESS_KEY",
    "secret_access_key": "YOUR_R2_SECRET_KEY",
    "public_base_url": "https://pub-xxxx.r2.dev/webar-targets",
    "prefix": ""
  }
}
